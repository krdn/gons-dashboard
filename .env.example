# gons-dashboard 환경 변수 템플릿
# 실제 값을 채운 뒤 .env 로 복사하여 사용. .env 는 절대 커밋하지 않는다.

# ===== LLM Proxy (Claude Code CLI Proxy) =====
LLM_PROXY_BASE_URL=http://192.168.0.5:8317
LLM_PROXY_API_KEY=replace-with-real-proxy-key

# ===== Google OAuth =====
# Google Cloud Console > OAuth client (External, Test 사용자에 본인 이메일 등록)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ===== NextAuth =====
# openssl rand -base64 32 로 생성
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3020

# ===== Database (Postgres on 192.168.0.5) =====
DATABASE_URL=postgresql://gons:CHANGE_ME@192.168.0.5:5440/gons_dashboard

# ===== Redis (192.168.0.5) =====
REDIS_URL=redis://192.168.0.5:6390

# ===== Cron 인증 (RUNBOOK 회전 절차 참조) =====
# openssl rand -hex 32 로 생성
CRON_BEARER_TOKEN=

# ===== Push 알림 (web-push VAPID) =====
# pnpm dlx web-push generate-vapid-keys 로 생성
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:your-email@example.com

# ===== 운영 알림 (OAuth 만료 등) =====
# OAuth 만료 시 외부 메일로 알림 받을 주소 (Gmail 외 다른 메일 권장)
OPS_NOTIFY_EMAIL=

# ===== Postgres pgcrypto 암호화 키 (refresh token at-rest) =====
# openssl rand -hex 32 로 생성
PG_ENCRYPTION_KEY=

# ===== Timezone (절대 변경 금지 — KST 8AM cron 정확성에 결정적) =====
TZ=Asia/Seoul
