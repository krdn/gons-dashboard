# gons-dashboard 환경 변수 템플릿
# 실제 값을 채운 뒤 .env 로 복사하여 사용. .env 는 절대 커밋하지 않는다.

# ===== LLM Proxy (Claude Code CLI Proxy) =====
# Anthropic SDK가 자동으로 인식하는 표준 환경변수 이름 사용
ANTHROPIC_BASE_URL=http://192.168.0.5:8317
ANTHROPIC_API_KEY=replace-with-real-proxy-key

# ===== Google OAuth =====
# Google Cloud Console > OAuth client (External, Test 사용자에 본인 이메일 등록)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ===== NextAuth =====
# openssl rand -base64 32 로 생성
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3020

# ===== Database (Postgres on 192.168.0.5) =====
DATABASE_URL=postgresql://gons:CHANGE_ME@192.168.0.5:5440/gons_dashboard

# ===== Redis (192.168.0.5) =====
REDIS_URL=redis://192.168.0.5:6390

# ===== Cron 인증 (RUNBOOK 회전 절차 참조) =====
# openssl rand -hex 32 로 생성
CRON_BEARER_TOKEN=

# ===== Push 알림 (web-push VAPID) =====
# pnpm dlx web-push generate-vapid-keys 로 생성
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:your-email@example.com

# ===== 운영 알림 (OAuth 만료 등) =====
# OAuth 만료 시 외부 메일로 알림 받을 주소 (Gmail 외 다른 메일 권장).
# 필수 — Zod email() 검증. 빈 문자열은 'Invalid email'로 부팅 실패.
OPS_NOTIFY_EMAIL=ops@example.com

# ===== Postgres pgcrypto 암호화 키 (refresh token at-rest) =====
# openssl rand -hex 32 로 생성
PG_ENCRYPTION_KEY=

# ===== Timezone (절대 변경 금지 — KST 8AM cron 정확성에 결정적) =====
TZ=Asia/Seoul

# 서버 인프라 모니터 v0.1
DOCKER_DEFAULT_CONTEXT=home-server
DOCKER_CMD_TIMEOUT_MS=10000
ADMIN_EMAILS=krdn.net@gmail.com

# ===== MCP mediator bearer =====
# openssl rand -hex 32 로 생성.
# 같은 값을 사용자 머신의 Claude Code MCP env에도 등록한다.
MCP_DASHBOARD_TOKEN=

# ===== 사주 상세 읽기 — features/saju-reading (spec §7) =====
SAJU_LLM_MODEL=claude-opus-4-7
SAJU_LLM_DAILY_BUDGET_KRW=1000
SAJU_LLM_TEMPERATURE=0.3

# === PlayMCP 1FATE (호 상담 영역) ===
PLAYMCP_GATEWAY_URL=https://playmcp.kakao.com/mcp
PLAYMCP_CLIENT_ID=HElMUWdVoroTsrXxezeTSemg8gXzzCKWARb5MJux8gY
# 초기 1회 setup 시 OTT 발급 후 입력. tiger:bootstrap 실행 후 .env 에서 제거.
PLAYMCP_BOOTSTRAP_OTT=

# ===== KRX OpenAPI AUTH_KEY (종목기본정보 시드) =====
# 발급: openapi.krx.co.kr 회원가입 → API 인증키 발급 → "주식 종목기본정보(sto/stk_isu_base_info,
# sto/ksq_isu_base_info)" 사용 신청 → 승인. 키 자체만 있으면 401 — 개별 API 신청 필수.
KRX_OPENAPI_AUTH_KEY=

# ===== DART OpenAPI (재무제표, PR 2) =====
# 발급: opendart.fss.or.kr 회원가입 → API 인증키 발급 (T+1).
# KR 종목 PBR/배당/trailing EPS/BPS overlay 용 (Yahoo 가 KR 종목엔 null 반환).
# Optional — 키 없으면 DART 어댑터 silent skip, yahoo-finance2 만 사용.
DART_OPENAPI_AUTH_KEY=

# 펀더멘털 소스 토글 (롤백 스위치, PR 2)
# - "yahoo+dart" (기본): yahoo-finance2 + DART overlay
# - "off": DART 비활성, yahoo-finance2 만 (PR #120 직후 동작 복귀)
STOCK_FUNDAMENTALS_SOURCES=yahoo+dart

# 사용자 1명당 등록 가능한 관심종목(watchlist) 최대 개수. 보유종목은 별도. 기본 10.
STOCK_WATCHLIST_MAX_PER_USER=10
